digraph "packages" {
rankdir=BT
charset="utf-8"
"app" [color="black", label=<app>, shape="box", style="solid"];
"app.config" [color="black", label=<app.config>, shape="box", style="solid"];
"app.domain" [color="black", label=<app.domain>, shape="box", style="solid"];
"app.main" [color="black", label=<app.main>, shape="box", style="solid"];
"app.repository" [color="black", label=<app.repository>, shape="box", style="solid"];
"app.repository.preprocessing" [color="black", label=<app.repository.preprocessing>, shape="box", style="solid"];
"app.repository.schema" [color="black", label=<app.repository.schema>, shape="box", style="solid"];
"app.service" [color="black", label=<app.service>, shape="box", style="solid"];
"app.service.inference_service" [color="black", label=<app.service.inference_service>, shape="box", style="solid"];
"app.service.report_service" [color="black", label=<app.service.report_service>, shape="box", style="solid"];
"app.ui" [color="black", label=<app.ui>, shape="box", style="solid"];
"app.main" -> "app.service.inference_service" [arrowhead="open", arrowtail="none"];
"app.main" -> "app.service.report_service" [arrowhead="open", arrowtail="none"];
"app.repository.preprocessing" -> "app.repository.schema" [arrowhead="open", arrowtail="none"];
"app.service.inference_service" -> "app.config" [arrowhead="open", arrowtail="none"];
"app.service.inference_service" -> "app.repository.preprocessing" [arrowhead="open", arrowtail="none"];
"app.service.inference_service" -> "app.repository.schema" [arrowhead="open", arrowtail="none"];
}
